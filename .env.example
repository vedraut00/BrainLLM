# Copy this file to ".env" and fill in ONE key.
# v1 uses a FREE provider tier — you sign up and get YOUR OWN free key (no card for Gemini).
# Switching provider = change these env vars only. No code change.

# ──────────────────────────────────────────────────────────────────────────────
# DEFAULT (recommended): Google Gemini — free tier, no credit card, big context
#   Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Defaults below are baked into the code for Gemini; uncomment only to override.
# CB_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# CB_LLM_MODEL=gemini-3.5-flash      # verify a current model id at the link above

# ──────────────────────────────────────────────────────────────────────────────
# ALTERNATIVE FREE TIERS (any OpenAI-compatible provider works — pick ONE)
#
# Groq (free, very fast):   https://console.groq.com/keys
#   GROQ_API_KEY=
#   CB_LLM_BASE_URL=https://api.groq.com/openai/v1
#   CB_LLM_MODEL=llama-3.3-70b-versatile
#
# OpenRouter (many free models): https://openrouter.ai/keys
#   OPENROUTER_API_KEY=
#   CB_LLM_BASE_URL=https://openrouter.ai/api/v1
#   CB_LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
#
# If a free model rejects JSON mode, disable it:
#   CB_LLM_JSON_MODE=0

# ──────────────────────────────────────────────────────────────────────────────
# Public base URL shown for your MCP endpoint (optional; defaults to localhost).
# CB_PUBLIC_MCP_BASE=http://localhost:8787
